<Window x:Class="WpfAppProjectBeheeder.NewProjectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppProjectBeheeder"
        mc:Ignorable="d"
        Title="NewProjectWindow" Height="680" Width="540"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="14">

            <GroupBox Header="Algemeen" Margin="0 0 0 10">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="TypeProject"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Name="CmbType" VerticalContentAlignment="Center"
                              SelectionChanged="CmbType_SelectionChanged">
                        <ComboBoxItem Content="StadsProject" IsSelected="True"/>
                        <ComboBoxItem Content="WonenProject"/>
                        <ComboBoxItem Content="GroenProject"/>
                    </ComboBox>

                    <Label Grid.Row="1" Content="Titel:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="TxtTitel" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="2" Content="StartDatum:"/>
                    <DatePicker Grid.Row="2" Grid.Column="1" Name="DpStart"/>

                    <Label Grid.Row="3" Content="Status:"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="CmbStatus" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Planning" IsSelected="True"/>
                        <ComboBoxItem Content="UitVoering"/>
                        <ComboBoxItem Content="Afgerond"/>
                    </ComboBox>

                    <Label Grid.Row="4" Content="Beschrijving:" VerticalAlignment="Top"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Name="TxtBeschrijving"
                             AcceptsReturn="True" TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Locatie" Margin="0 0 0 10">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Gemeente:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="TxtGemeente" Text="Gent" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="1" Content="PostCode:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="TxtPostCode" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="2" Content="Straat:"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="TxtStraat" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="3" Content="HuisNummer:"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Name="TxtHuisNummer" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="4" Content="Wijk:"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Name="TxtWijk" VerticalContentAlignment="Center"/>
                </Grid>
            </GroupBox>
            <!-- StadsProject -->
                <GroupBox Name="GbStads" Header="Stadsproject details" Margin="0 0 0 10">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Vergunningstatus:"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Name="CmbVergunning" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="InAanvraag" IsSelected="True"/>
                        <ComboBoxItem Content="Goedgekeurd"/>
                        <ComboBoxItem Content="Geweigerd"/>
                    </ComboBox>
                    <Label Grid.Row="1" Content="Architecturale waarde:"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" Name="ChkArchWaarde" VerticalAlignment="Center"/>
                    <Label Grid.Row="2" Content="Toegankelijkheid:"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" Name="CmbToegang" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="VolledigOpenbaar" IsSelected="True"/>
                        <ComboBoxItem Content="Gedeeltelijk"/>
                        <ComboBoxItem Content="Gesloten"/>
                    </ComboBox>
                    <Label Grid.Row="3" Content="Toeristische waarde:"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" Name="ChkToeristisch" VerticalAlignment="Center"/>
                    <Label Grid.Row="4" Content="Infowandeling voorzien:"/>
                    <CheckBox Grid.Row="4" Grid.Column="1" Name="ChkInfowandeling" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>
            
            <!-- GroenProject -->
            <GroupBox Name="GbGroen" Header="Groen project details" Margin="0 0 0 10" Visibility="Collapsed">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Oppervlakte (m²):"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="TxtOppervlakte" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="1" Content="Biodiversiteitscore (0-10):"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="TxtBioScore" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="2" Content="Aantal wandelpaden:"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Name="TxtWandelpaden" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="3" Content="Faciliteiten:"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Name="TxtFaciliteiten" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="4" Content="Toeristische route:"/>
                    <CheckBox Grid.Row="4" Grid.Column="1" Name="ChkToerRoute" VerticalAlignment="Center"/>
                    <Label Grid.Row="5" Content="Beoordeling (0-5):"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Name="TxtBeoordeling" VerticalContentAlignment="Center"/>
                </Grid>
            </GroupBox>
            <!-- WonenProject -->
            <GroupBox Name="GbInno" Header="Wonen project details" Margin="0 0 0 10" Visibility="Collapsed">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Aantal eenheden:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="TxtEenheden" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="1" Content="Woning types:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Name="TxtWoningTypes" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="2" Content="Rondleidingen mogelijk:"/>
                    <CheckBox Grid.Row="2" Grid.Column="1" Name="ChkRondleiding" VerticalAlignment="Center"/>
                    <Label Grid.Row="3" Content="Showwoning beschikbaar:"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" Name="ChkShowwoning" VerticalAlignment="Center"/>
                    <Label Grid.Row="4" Content="Innovatie score (0-10):"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Name="TxtInnoScore" VerticalContentAlignment="Center"/>
                    <Label Grid.Row="5" Content="Erfgoed samenwerking:"/>
                    <CheckBox Grid.Row="5" Grid.Column="1" Name="ChkErfgoed" VerticalAlignment="Center"/>
                </Grid>
            </GroupBox>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 6 0 0">
                <Button Content="Opslaan"  Width="90" Click="Opslaan_Click"/>
                <Button Content="Annuleer" Width="90" Margin="8 0 0 0" Click="Annuleer_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
