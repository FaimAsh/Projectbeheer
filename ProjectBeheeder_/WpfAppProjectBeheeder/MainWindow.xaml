<Window x:Class="WpfAppProjectBeheeder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppProjectBeheeder"
        mc:Ignorable="d"
        Title="MainWindow" Height="640" Width="1060"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">
        <GroupBox DockPanel.Dock="Top" Header="Zoeken &amp; Filteren" Margin="0 0 0 8">
            <Grid Margin="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="35"/>
                </Grid.RowDefinitions>
                    <Label Grid.Column="0" Content="Type:" Margin="50 0 0 0" VerticalAlignment="Center"/>
                <Label Grid.Column="1" Content="StadsProject:" Margin="0 0 0 0" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" Grid.Row="0" Name="ChkBowfirma" Margin="60 0 0 0" VerticalAlignment="Center" HorizontalAlignment="Center" IsChecked="True"/>
                <Label Grid.Column="1" Grid.Row="1" Content="GroenProject:" Margin="0 0 0 0" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" Grid.Row="1" Name="ChkBuwfirma" Margin="60 0 0 0" VerticalAlignment="Center" HorizontalAlignment="Center" IsChecked="True"/>
                <Label Grid.Column="1" Grid.Row="2" Content="WoonProject:" Margin="0 0 0 0" VerticalAlignment="Center"/>
                <CheckBox Grid.Column="1" Grid.Row="2" Name="ChkBouwfirma" Margin="60 0 0 0" VerticalAlignment="Center" HorizontalAlignment="Center" IsChecked="True"/>

                    <Label Grid.Column="2" Content="Status:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="3" Name="CmbStatus" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="(alle)"   IsSelected="True"/>
                    <ComboBoxItem Content="Planning"/>
                    <ComboBoxItem Content="UitVoering"/>
                    <ComboBoxItem Content="Afgerond"/>
                </ComboBox>

                <Label Grid.Column="4" Content="Wijk:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="5" Name="TxtWijk" Width="100" Margin="0 0 10 0" VerticalAlignment="Center"/>

                    <Label Grid.Column="6" Content="Partner:" VerticalAlignment="Center"/>
                <TextBox Grid.Column="7" Name="TxtPartner" Width="120" Margin="0 0 10 0" VerticalAlignment="Center"/>
                    <Label Grid.Column="8" Content="Van:" VerticalAlignment="Center"/>
                <DatePicker Grid.Column="9" Name="DpVan" Width="120" Margin="0 0 6 0" VerticalAlignment="Center"/>
                    <Label Grid.Column="10" Content="Tot:" VerticalAlignment="Center"/>
                <DatePicker Grid.Column="11" Name="DpTot" Width="120" Margin="0 0 10 0" VerticalAlignment="Center"/>
                <Button Grid.Column="11" Grid.Row="2" Content="Zoeken" Width="80" Click="Zoeken_Click"/>
                <Button Grid.Column="9" Grid.Row="2" Content="Reset" Width="60" Height="25" Margin="0 0 0 0" Click="Reset_Click"/>
            </Grid>
        </GroupBox>
        
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0 0 0 8" RenderTransformOrigin="0.729,0.709">
            <Button Content="Nieuw"      Width="90" Click="NieuwProject_Click"/>
            <Button Content="Wijzig"     Width="80" Margin="6 0" Click="WijzigProject_Click"/>
            <Button Content="Verwijder"  Width="85" Click="VerwijderProject_Click"/>
            <Button Content="Meer Info"     Width="85" Margin="6 0" Click="Info_Click"/>
            <Button Content="Voeg Partner toe"   Width="110" Click="Partners_Click"/>
            <Button Content="Export CSV" Width="90" Margin="16 0 0 0" Click="ExportCSV_Click"/>
            <Button Content="Export PDF" Width="90" Margin="6 0 0 0" Click="ExportPDF_Click"/>
        </StackPanel>

        <DataGrid Name="DgProjecten" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single"
                  SelectionChanged="DgProjecten_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                <DataGridTextColumn Header="Naam" Binding="{Binding Naam}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="Auto"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto"/>
                <DataGridTextColumn Header="Wijk" Binding="{Binding Wijk}" Width="Auto"/>
                <DataGridTextColumn Header="Partner" Binding="{Binding Partner}" Width="Auto"/>
                <DataGridTextColumn Header="StartDatum" Binding="{Binding StartDatum, StringFormat=d}" Width="Auto"/>
                <DataGridTextColumn Header="EindDatum" Binding="{Binding EindDatum, StringFormat=d}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
